# Nexus HQ — env vars (names only; get values from Jason / Vercel)
# Same Supabase project as the main Nexus app.

# Client-safe (anon key is public by design; RLS enforces access)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefix these with NEXT_PUBLIC_
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — LIVE mode key (main repo's .env.local is TEST; do not reuse it)
STRIPE_SECRET_KEY=

# Anthropic Admin API key (console.anthropic.com -> Settings -> Admin keys).
# Separate from the model-calling key the main site uses. Usage/cost reporting only.
ANTHROPIC_ADMIN_KEY=
